# webmcp-gen environment variables

# OpenAI API key (for --llm mode with GPT models)
OPENAI_API_KEY=sk-...

# OR use a generic LLM_API_KEY (works with any OpenAI-compatible API)
# LLM_API_KEY=your-key-here

# For local models (Ollama), no key needed — just use:
#   --base-url http://localhost:11434/v1 --model llama3
